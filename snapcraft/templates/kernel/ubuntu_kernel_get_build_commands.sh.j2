# Ubuntu kernel snapcraft build script
# Generated by snapcraft ubuntu-kernel plugin.
# ----
# Build on:  {{ craft_arch_build_on }}
# Build for: {{ craft_arch_build_for }}
# Snapcraft version: {{ snap_version }}
# Snap data: {{ snap_data_path }}
# Snap context: {{ snap_context }}
# ----
# TODO(esh) remove; handy for debug, --debug and --shell has a different env
# Ignore SC1091 "Not following: x/y/z.sh was not specified as input"
shellcheck -e SC1091 "$0"
env

# TODO(esh) these `rm` are for debug only, rely on `snapcraft clean`
# instead
cd {{ craft_part_build_dir }}
rm -fr {{ craft_part_build_dir }}/kernel/
rm -fr {{ craft_part_build_dir }}/unpacked-*
rm -fr {{ craft_part_install_dir }}/*

mkdir {{ craft_part_build_dir }}/kernel
# Get source deb packages into build arena
{% if ubuntu_kernel_use_binary_package %}
    echo "(II) Using prebuilt kernel deb packages"
    rsync -aH {{ craft_part_src_dir }}/*.deb {{ craft_part_build_dir }}/kernel
{% else %}
    echo "(II) Building kernel deb packages from source"
    {% include "kernel/ubuntu_kernel_build_kernel_debs.sh.j2" %}
    mv {{ craft_part_build_dir }}/*.deb {{ craft_part_build_dir}}/kernel
{% endif %}

echo "(II) Building kernel snap from debian images"

cd {{ craft_part_build_dir }}/kernel

LINUX_IMAGE_DEB=$(linux-image-*.deb)
# Ensure there is only one linux-image deb package and it really is a file
if [ "${LINUX_IMAGE_DEB[@]}" -eq 1 ] && [ -e "${LINUX_IMAGE_DEB[0]}" ]; then
    dpkg-deb -R "${LINUX_IMAGE_DEB[0]}" unpacked-linux-image
else
    echo "(EE) multiple linux image deb packages found."
    exit 1
fi

dpkg-deb -R linux-modules-${KERNEL_ABI}-{{ ubuntu_kernel_flavour }}_${KERNEL_VERSION}_{{
for debfile in linux-modules-*.deb; do
    dpkg-deb -x debfile unpacked-linux-modules
done

{% for dkms in ubuntu_kernel_dkms %}
dpkg-deb -x \
    linux-headers-{{ kernel_abi }}_{{ kernel_version }}_all.deb unpacked-linux-header
dpkg-deb -x \
    linux-headers-{{ kernel_abi }}-{{ ubuntu_kernel_flavour }}_{{ kernel_version }}_{{ target_arch }}.deb
{% endfor %}


# Unpack the linux deb binaries to snap package structure
mv unpacked-linux-image/* {{ craft_part_install_dir }}
mkdir {{ craft_part_install_dir }}/lib
mv unpacked-linux-modules/lib/modules {{ craft_part_install_dir }}/lib/
mv unpacked-linux-modules/boot/* {{ craft_part_install_dir }}/boot/
depmod -b {{ craft_part_install_dir }} "${KERNEL_ABI}"-{{ ubuntu_kernel_flavour }}


# ITERATE OVER DKMS PACKAGES
#for pkg in $(ls linux-modules-*.deb); do
#    unpack_path=unpacked-$(echo "$pkg" | cut -d '-' -f 1-2)
#    dpkg-deb -R "$pkg" "$unpack_path"/
#    mv ${unpack_path}/lib/modules/* {{ craft_part_install_dir }}/modules/
#done


# Manipulate stock kernel layout to the snapcraft package layout.
mv {{ craft_part_install_dir }}/boot/* {{ craft_part_install_dir }}/
ln -f {{ craft_part_install_dir }}/vmlinuz-"${KERNEL_ABI}"-{{ ubuntu_kernel_flavour }} {{ craft_part_install_dir }}/kernel.img
mv {{ craft_part_install_dir }}/lib/modules {{ craft_part_install_dir }}/

# Device tree
DTBS=unpacked-linux-firmware/{{ craft_part_install_dir }}/lib/firmware/"${KERNEL_ABI}"/device-tree
[ -d "${DTBS}" ] && mv "${DTBS}" {{ craft_part_install_dir }}/dtbs

# Firmware
FIRMWARE=unpacked-linux-firmware/{{ craft_part_install_dir }}/lib/firmware/"${KERNEL_ABI}"
[ -d "${FIRMWARE}" ] && mv "${FIRMWARE}" {{ craft_part_install_dir }}/firmware
rm -rf {{ craft_part_install_dir }}/boot
